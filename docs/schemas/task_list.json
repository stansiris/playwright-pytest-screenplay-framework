{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taskhub/task_list",
  "title": "TaskList",
  "description": "Response from GET /api/tasks",
  "type": "object",
  "required": ["items"],
  "additionalProperties": false,
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "$ref": "task.json"
      }
    }
  }
}
