{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taskhub/task",
  "title": "Task",
  "description": "A single TaskHub task as returned by the API",
  "type": "object",
  "required": ["id", "title", "status", "priority", "created_at", "updated_at", "owner_username"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "COMPLETED"]
    },
    "priority": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    },
    "due_date": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "owner_username": {
      "type": "string",
      "minLength": 1
    }
  }
}
